# ============================================================
# NIFTY Quant Lab — Environment Variables
# ============================================================
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nifty_quant_lab
DB_USER=root
DB_PASSWORD=your_mysql_root_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── API Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
DEBUG=false
LOG_LEVEL=INFO

# ── Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_or_group_chat_id
TELEGRAM_ALERT_CHAT_ID=your_alert_channel_id

# ── Zerodha KiteConnect (Phase 2+)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_USER_ID=PR5573
ZERODHA_ACCESS_TOKEN=       # refreshed daily

# ── Angel One SmartAPI (Phase 2+)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# ── AI Signals (Phase 3)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── pgAdmin (Docker dev only)
PGADMIN_PASSWORD=admin
